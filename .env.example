# GitHub personal access token.
# Fine-grained PAT recommended. Required scopes for full feature set:
#   - Contents: write
#   - Administration: write
#   - Metadata: read
#   - Workflows: write
#   - Pull requests: write
#   - Issues: write
#   - Secrets: write
#   - Pages: write
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub API base URL. Override only for GitHub Enterprise Server.
# Default: https://api.github.com
GITHUB_API_URL=https://api.github.com

# Default visibility for new repos created by github_create_repo.
# One of: public, private, internal (internal = orgs only)
DEFAULT_REPO_VISIBILITY=public
